{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "Base.json"
  ],
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "default",
      "description": "Windows platform base configuration",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows MSVC compiler - Debug configuration",
      "inherits": ["windows-base", "vs2022", "debug"]
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "description": "Windows MSVC compiler - Release configuration with debug info",
      "inherits": ["windows-base", "vs2022", "release-with-debug"]
    },
    {
      "name": "windows-mingw-debug",
      "displayName": "Windows MinGW Debug",
      "description": "Windows MinGW compiler - Debug configuration",
      "inherits": ["windows-base", "ninja", "mingw", "debug"]
    },
    {
      "name": "windows-mingw-release",
      "displayName": "Windows MinGW Release",
      "description": "Windows MinGW compiler - Release configuration",
      "inherits": ["windows-base", "ninja", "mingw", "release"]
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "inherits": "build-base",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-release",
      "inherits": "build-base",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "windows-mingw-debug",
      "inherits": "build-base",
      "configurePreset": "windows-mingw-debug"
    },
    {
      "name": "windows-mingw-release",
      "inherits": "build-base",
      "configurePreset": "windows-mingw-release"
    }
  ],
  "packagePresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "generators": ["ZIP"]
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "generators": ["ZIP"]
    },
    {
      "name": "windows-mingw-debug",
      "configurePreset": "windows-mingw-debug",
      "generators": ["ZIP"]
    },
    {
      "name": "windows-mingw-release",
      "configurePreset": "windows-mingw-release",
      "generators": ["ZIP"]
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "inherits": "test-base"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "inherits": "test-base"
    },
    {
      "name": "windows-mingw-debug",
      "configurePreset": "windows-mingw-debug",
      "inherits": "test-base"
    },
    {
      "name": "windows-mingw-release",
      "configurePreset": "windows-mingw-release",
      "inherits": "test-base"
    }
  ]
}
