{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        // ==================== Active CMake launch target ====================
        {
            "name": "CMake Launch (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.getLaunchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [
                {
                    "name": "PATH",
                    "value": "${command:cmake.getLaunchTargetDirectory};${command:cmake.buildDirectory}/bin;${env:PATH}"
                }
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "CMake Launch (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.getLaunchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${command:cmake.getLaunchTargetDirectory}:${command:cmake.buildDirectory}/bin:${env:LD_LIBRARY_PATH}"
                }
            ],
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "CMake Launch (macOS)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.getLaunchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [
                {
                    "name": "DYLD_LIBRARY_PATH",
                    "value": "${command:cmake.getLaunchTargetDirectory}:${command:cmake.buildDirectory}/bin:${env:DYLD_LIBRARY_PATH}"
                }
            ],
            "MIMode": "lldb"
        }
    ]
}
